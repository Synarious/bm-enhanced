export default {
  async fetch(request) {
    const url = new URL(request.url);
    if (url.pathname === '/updates.xml') {
      return new Response(`<?xml version="1.0" encoding="UTF-8"?>
<gupdate xmlns="http://www.google.com/update2/response" protocol="2.0">
  <app appid="YOUR_EXTENSION_ID">
    <updatecheck codebase="https://<your-worker-subdomain>.workers.dev/update.crx" version="1.0.0" />
  </app>
</gupdate>`, {
        headers: { 'Content-Type': 'text/xml' },
      });
    }

    if (url.pathname === '/update.crx') {
      return fetch('https://github.com/<user>/<repo>/releases/latest/download/update.crx');
    }

    return new Response("Not Found", { status: 404 });
  }
}